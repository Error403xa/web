{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Information"
    }
  },
  "AllowedHosts": "*",
  "DeviceServer": {
    "Port": 4441,
    "TimeoutSeconds": 120
  },
  "ScreenReader": {
    "MaxQueueSize": 10,
    "MaxLatency": 1000,
    "DropThreshold": 5,
    "EnablePerformanceLog": true
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  }
}

